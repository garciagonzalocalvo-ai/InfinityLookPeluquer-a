<script>
  // Scroll reveal
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => entry.target.classList.add('visible'), i * 80);
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12 });

  reveals.forEach(el => observer.observe(el));

  // Hide FAB when at CTA section
  const fabEl = document.querySelector('.fab');
  const ctaSection = document.getElementById('reservar');
  const fabObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      fabEl.style.opacity = entry.isIntersecting ? '0' : '';
      fabEl.style.pointerEvents = entry.isIntersecting ? 'none' : '';
    });
  }, { threshold: 0.3 });
  fabObserver.observe(ctaSection);

  // Smooth nav background on scroll
  const nav = document.querySelector('nav');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      nav.style.boxShadow = '0 2px 20px rgba(44,36,32,0.08)';
    } else {
      nav.style.boxShadow = 'none';
    }
  });
</script>
